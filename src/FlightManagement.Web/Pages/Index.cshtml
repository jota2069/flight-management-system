@page
@model FlightManagement.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Расписание рейсов";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8"/>
    <title>Табло рейсов</title>
    <style>
        * { box-sizing: border-box; }
        body { font-family: Arial, sans-serif; background: #1a1a2e; color: white; margin: 0; padding: 20px; }
        h1, h2 { color: #e94560; }
        table { width: 100%; border-collapse: collapse; margin-top: 16px; }
        th { background: #0f3460; padding: 12px; text-align: left; color: #a8b2d8; }
        td { padding: 10px; border-bottom: 1px solid #0f3460; vertical-align: middle; }
        tr:hover { background: #16213e; }
        .nav { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .btn { padding: 8px 16px; border-radius: 6px; font-size: 14px; cursor: pointer; border: none; color: white; text-decoration: none; display: inline-block; }
        .btn-red { background: #e94560; }
        .btn-blue { background: #0f3460; }
        .btn-green { background: #1a6b3a; }
        .btn-orange { background: #c77b00; }
        .btn-sm { padding: 5px 12px; font-size: 12px; }
        .tabs { display: flex; gap: 8px; margin-bottom: 20px; }
        .tab { padding: 10px 22px; border-radius: 8px 8px 0 0; cursor: pointer; background: #0f3460; color: #a8b2d8; border: none; font-size: 14px; }
        .tab.active { background: #e94560; color: white; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .status { padding: 4px 10px; border-radius: 20px; font-size: 12px; }
        .scheduled { background: #1a472a; color: #51cf66; }
        .cancelled { background: #4a1a1a; color: #ff6b6b; }
        .confirmed { background: #1a3a6b; color: #74b3ff; }
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 100; justify-content: center; align-items: center; }
        .modal-overlay.open { display: flex; }
        .modal { background: #16213e; padding: 32px; border-radius: 14px; width: 480px; max-width: 95vw; border: 1px solid #0f3460; }
        .modal h2 { margin-top: 0; }
        .modal-close { float: right; background: none; border: none; color: #a8b2d8; font-size: 22px; cursor: pointer; margin-top: -8px; }
        input, select { width: 100%; padding: 10px; margin: 5px 0 14px; border: 1px solid #0f3460; border-radius: 6px; background: #0f3460; color: white; font-size: 14px; }
        label { color: #a8b2d8; font-size: 13px; }
        .success { color: #51cf66; padding: 10px; background: #1a472a; border-radius: 6px; margin-bottom: 16px; }
        .error { color: #ff6b6b; padding: 10px; background: #4a1a1a; border-radius: 6px; margin-bottom: 16px; }
        .info-row { display: flex; gap: 20px; margin-bottom: 20px; }
        .info-card { background: #16213e; border-radius: 10px; padding: 16px 24px; flex: 1; text-align: center; }
        .info-card .num { font-size: 28px; font-weight: bold; color: #e94560; }
        .info-card .lbl { font-size: 12px; color: #a8b2d8; margin-top: 4px; }
        .empty { text-align: center; color: #a8b2d8; padding: 40px; font-size: 15px; }
    </style>
</head>
<body>

<div class="nav">
    <h1>✈️ Система управления рейсами</h1>
    <div style="display:flex; gap:10px; align-items:center;">
        <span style="color:#a8b2d8; font-size:13px;">Привет, @User.Identity?.Name!</span>
        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-blue" href="/Admin">Админ-панель</a>
        }
        <form method="post" asp-page-handler="Logout" style="display:inline;">
            <button class="btn btn-red" type="submit">Выйти</button>
        </form>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="@(Model.IsError ? "error" : "success")">@Model.Message</div>
}

<div class="info-row">
    <div class="info-card">
        <div class="num">@Model.Flights.Count</div>
        <div class="lbl">Доступных рейсов</div>
    </div>
    <div class="info-card">
        <div class="num">@Model.MyTickets.Count</div>
        <div class="lbl">Моих билетов</div>
    </div>
    <div class="info-card">
        <div class="num">@Model.Flights.Count(f => f.Status == "Scheduled")</div>
        <div class="lbl">По расписанию</div>
    </div>
</div>

<div class="tabs">
    <button class="tab active" onclick="switchTab('flights', this)">✈️ Расписание рейсов</button>
    <button class="tab" onclick="switchTab('tickets', this)">🎫 Мои билеты</button>
</div>

<!-- Вкладка: Расписание -->
<div id="tab-flights" class="tab-content active">
    <table>
        <thead>
            <tr>
                <th>Рейс</th>
                <th>Откуда</th>
                <th>Куда</th>
                <th>Вылет</th>
                <th>Прилёт</th>
                <th>Мест</th>
                <th>Статус</th>
                <th>Действие</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var flight in Model.Flights)
            {
                <tr>
                    <td><strong>@flight.FlightNumber</strong></td>
                    <td>@flight.Origin</td>
                    <td>@flight.Destination</td>
                    <td>@flight.DepartureTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@flight.ArrivalTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@flight.TotalSeats</td>
                    <td><span class="status scheduled">@flight.Status</span></td>
                    <td>
                        <button class="btn btn-green btn-sm"
                                onclick="openBooking(@flight.Id, '@flight.FlightNumber', '@flight.Origin', '@flight.Destination', '@flight.DepartureTime.ToString("dd.MM.yyyy HH:mm")')">
                            Забронировать
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Вкладка: Мои билеты -->
<div id="tab-tickets" class="tab-content">
    @if (Model.MyTickets.Count == 0)
    {
        <div class="empty">У вас пока нет билетов. Перейдите на вкладку «Расписание» и забронируйте рейс!</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>№ билета</th>
                    <th>Рейс</th>
                    <th>Маршрут</th>
                    <th>Вылет</th>
                    <th>Место</th>
                    <th>Цена</th>
                    <th>Статус</th>
                    <th>Действие</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model.MyTickets)
                {
                    <tr>
                        <td>#@ticket.Id</td>
                        <td><strong>@ticket.Flight?.FlightNumber</strong></td>
                        <td>@ticket.Flight?.Origin → @ticket.Flight?.Destination</td>
                        <td>@ticket.Flight?.DepartureTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@ticket.SeatNumber</td>
                        <td>@ticket.Price.ToString("N0") ₽</td>
                        <td><span class="status confirmed">@ticket.Status</span></td>
                        <td>
                            <form method="post" asp-page-handler="CancelTicket"
                                  onsubmit="return confirm('Отменить билет #@ticket.Id?')">
                                <input type="hidden" name="ticketId" value="@ticket.Id"/>
                                <button class="btn btn-orange btn-sm" type="submit">Отменить</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Модальное окно бронирования -->
<div class="modal-overlay" id="bookingModal">
    <div class="modal">
        <button class="modal-close" onclick="closeBooking()">✕</button>
        <h2>Бронирование билета</h2>
        <div id="flightInfo" style="background:#0f3460; border-radius:8px; padding:12px; margin-bottom:20px; font-size:14px; color:#a8b2d8;"></div>

        <form method="post" asp-page-handler="Book">
            <input type="hidden" id="bookFlightId" name="BookForm.FlightId"/>

            <label>Имя</label>
            <input type="text" asp-for="BookForm.FirstName" placeholder="Иван"/>

            <label>Фамилия</label>
            <input type="text" asp-for="BookForm.LastName" placeholder="Иванов"/>

            <label>Серия и номер паспорта</label>
            <input type="text" asp-for="BookForm.PassportNumber" placeholder="1234567890"/>

            <label>Email</label>
            <input type="email" asp-for="BookForm.Email" placeholder="ivan@example.com"/>

            <label>Телефон</label>
            <input type="text" asp-for="BookForm.Phone" placeholder="+79001234567"/>

            <label>Дата рождения</label>
            <input type="date" asp-for="BookForm.DateOfBirth"/>

            <label>Номер места</label>
            <input type="text" asp-for="BookForm.SeatNumber" placeholder="12A"/>

            <label>Цена (₽)</label>
            <input type="number" asp-for="BookForm.Price" placeholder="5000" min="0"/>

            <div style="display:flex; gap:10px; margin-top:8px;">
                <button type="submit" class="btn btn-green" style="flex:1;">Подтвердить бронирование</button>
                <button type="button" class="btn btn-red" onclick="closeBooking()" style="flex:1;">Отмена</button>
            </div>
        </form>
    </div>
</div>

<script>
function switchTab(name, btn) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.getElementById('tab-' + name).classList.add('active');
    btn.classList.add('active');
}

function openBooking(id, num, from, to, dep) {
    document.getElementById('bookFlightId').value = id;
    document.getElementById('flightInfo').innerHTML =
        '✈️ <strong>' + num + '</strong> &nbsp;|&nbsp; ' + from + ' → ' + to + ' &nbsp;|&nbsp; Вылет: ' + dep;
    document.getElementById('bookingModal').classList.add('open');
}

function closeBooking() {
    document.getElementById('bookingModal').classList.remove('open');
}

window.onclick = function(e) {
    const modal = document.getElementById('bookingModal');
    if (e.target === modal) closeBooking();
}
</script>
</body>
</html>