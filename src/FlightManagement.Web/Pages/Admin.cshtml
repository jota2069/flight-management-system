@page
@model FlightManagement.Web.Pages.AdminModel
@{
    ViewData["Title"] = "Админ-панель";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8"/>
    <title>Админ-панель</title>
    <style>
        body { font-family: Arial, sans-serif; background: #1a1a2e; color: white; margin: 0; padding: 20px; }
        h1, h2 { color: #e94560; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { background: #0f3460; padding: 12px; text-align: left; color: #a8b2d8; }
        td { padding: 10px; border-bottom: 1px solid #0f3460; }
        tr:hover { background: #16213e; }
        .nav { display: flex; justify-content: space-between; align-items: center; }
        .btn { padding: 8px 16px; border-radius: 6px; font-size: 14px; cursor: pointer; border: none; color: white; text-decoration: none; }
        .btn-red { background: #e94560; }
        .btn-blue { background: #0f3460; }
        .btn-green { background: #1a472a; }
        .btn-sm { padding: 4px 10px; font-size: 12px; }
        .form-card { background: #16213e; padding: 24px; border-radius: 12px; margin-top: 30px; }
        input, select { width: 100%; padding: 10px; margin: 6px 0 14px; border: 1px solid #0f3460; border-radius: 6px; background: #0f3460; color: white; box-sizing: border-box; }
        label { color: #a8b2d8; font-size: 14px; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .success { color: #51cf66; margin-top: 10px; }
        .error { color: #e94560; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="nav">
        <h1>⚙️ Админ-панель</h1>
        <div>
            <a class="btn btn-blue" href="/Index">Табло</a>
            <form method="post" asp-page-handler="Logout" style="display:inline; margin-left:8px;">
                <button class="btn btn-red" type="submit">Выйти</button>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <p class="@(Model.IsError ? "error" : "success")">@Model.Message</p>
    }

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Рейс</th>
                <th>Откуда</th>
                <th>Куда</th>
                <th>Вылет</th>
                <th>Прилёт</th>
                <th>Мест</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var flight in Model.Flights)
            {
                <tr>
                    <td>@flight.Id</td>
                    <td>@flight.FlightNumber</td>
                    <td>@flight.Origin</td>
                    <td>@flight.Destination</td>
                    <td>@flight.DepartureTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@flight.ArrivalTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@flight.TotalSeats</td>
                    <td>@flight.Status</td>
                    <td>
                        <form method="post" asp-page-handler="Delete" style="display:inline;">
                            <input type="hidden" name="id" value="@flight.Id"/>
                            <button class="btn btn-red btn-sm" type="submit">Удалить</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="form-card">
        <h2>Добавить рейс</h2>
        <form method="post" asp-page-handler="Create">
            <div class="grid">
                <div>
                    <label>Номер рейса</label>
                    <input type="text" asp-for="Input.FlightNumber" placeholder="SU-404"/>
                    <label>Откуда</label>
                    <input type="text" asp-for="Input.Origin" placeholder="Москва"/>
                    <label>Куда</label>
                    <input type="text" asp-for="Input.Destination" placeholder="Сочи"/>
                </div>
                <div>
                    <label>Дата вылета</label>
                    <input type="datetime-local" asp-for="Input.DepartureTime"/>
                    <label>Дата прилёта</label>
                    <input type="datetime-local" asp-for="Input.ArrivalTime"/>
                    <label>Количество мест</label>
                    <input type="number" asp-for="Input.TotalSeats" placeholder="150"/>
                </div>
            </div>
            <button class="btn btn-green" type="submit">Добавить рейс</button>
        </form>
    </div>
</body>
</html>